# Шаблон переменных окружения. Скопируй в .env и заполни значения:
#   cp .env.example .env
# Файл .env в git НЕ коммитим (см. .gitignore).

# --- База данных ---
DB_URL=jdbc:postgresql://localhost:5432/travel_budget
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --- JWT ---
# Секрет для подписи токенов (HS256). Минимум 32 символа (256 бит).
# Сгенерировать случайный: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-minimum-256-bits

# --- AI (Claude API) ---
AI_API_KEY=sk-ant-your-key-here
